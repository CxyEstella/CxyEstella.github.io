---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { withBase } from '@/lib/urls';
import '@/styles/global.css';
import { SITE_DESCRIPTION, SITE_TITLE } from '@/site.config';

interface Props {
  title?: string;
  description?: string;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION } = Astro.props;
const pageTitle = title === SITE_TITLE ? SITE_TITLE : `${title} | ${SITE_TITLE}`;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0b0d10" />
    <meta name="color-scheme" content="light dark" />
    {canonical && <link rel="canonical" href={canonical.toString()} />}
    <link rel="icon" type="image/jpeg" href={withBase('/brand-logo.jpg')} />
    <link rel="apple-touch-icon" href={withBase('/brand-logo.jpg')} />
    <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={withBase('/feed.xml')} />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        let saved = null;
        let preferred = 'light';

        try {
          saved = window.localStorage.getItem('theme');
          preferred = window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
        } catch {
          preferred = 'light';
        }

        document.documentElement.dataset.theme = saved ?? preferred;
      })();
    </script>
  </head>
  <body>
    <div class="page-backdrop" aria-hidden="true"></div>
    <Header />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
