---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import {
  collectionMeta,
  estimateReadingMinutes,
  formatDate,
  type AnyEntry,
} from '@/lib/content';
import { withBase } from '@/lib/urls';

interface HeadingItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  entry: AnyEntry;
  headings: HeadingItem[];
}

const { entry, headings } = Astro.props;
const meta = collectionMeta[entry.collection];
const cover = entry.data.cover;
const coverSrc = typeof cover === 'string' ? cover : cover?.src;
const coverWidth = typeof cover === 'string' ? undefined : cover?.width;
const coverHeight = typeof cover === 'string' ? undefined : cover?.height;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="container post-shell">
    <header class="post-header">
      <a class="post-header__back" href={withBase(`/${entry.collection}/`)}>
        Back to {meta.title}
      </a>

      <div class="post-header__eyebrow">
        <span>{meta.title}</span>
        <span>{formatDate(entry.data.pubDate)}</span>
        <span>{estimateReadingMinutes(entry)} min read</span>
      </div>

      <h1>{entry.data.title}</h1>
      <p class="post-header__description">{entry.data.description}</p>

      {
        coverSrc && (
          <img
            class="post-cover"
            src={coverSrc}
            width={coverWidth}
            height={coverHeight}
            alt={entry.data.coverAlt ?? entry.data.title}
            loading="eager"
          />
        )
      }

      {
        entry.collection === 'reading' && (
          <dl class="meta-grid">
            {entry.data.authors.length > 0 && (
              <>
                <dt>Authors</dt>
                <dd>{entry.data.authors.join(' / ')}</dd>
              </>
            )}
            {entry.data.source && (
              <>
                <dt>Source</dt>
                <dd>{entry.data.source}</dd>
              </>
            )}
            {entry.data.year && (
              <>
                <dt>Year</dt>
                <dd>{entry.data.year}</dd>
              </>
            )}
            {entry.data.paperUrl && (
              <>
                <dt>Paper</dt>
                <dd>
                  <a href={entry.data.paperUrl} target="_blank" rel="noreferrer">
                    Open link
                  </a>
                </dd>
              </>
            )}
            {entry.data.takeaway && (
              <>
                <dt>Takeaway</dt>
                <dd>{entry.data.takeaway}</dd>
              </>
            )}
          </dl>
        )
      }

      {
        entry.collection === 'projects' && (
          <dl class="meta-grid">
            <dt>Status</dt>
            <dd>{entry.data.status}</dd>
            {entry.data.stack.length > 0 && (
              <>
                <dt>Stack</dt>
                <dd>{entry.data.stack.join(' / ')}</dd>
              </>
            )}
            {entry.data.startedDate && (
              <>
                <dt>Started</dt>
                <dd>{formatDate(entry.data.startedDate)}</dd>
              </>
            )}
            {entry.data.finishedDate && (
              <>
                <dt>Finished</dt>
                <dd>{formatDate(entry.data.finishedDate)}</dd>
              </>
            )}
            {entry.data.repoUrl && (
              <>
                <dt>Repo</dt>
                <dd>
                  <a href={entry.data.repoUrl} target="_blank" rel="noreferrer">
                    Open repository
                  </a>
                </dd>
              </>
            )}
          </dl>
        )
      }
    </header>

    <div class="post-layout">
      <aside class="post-sidebar">
        <TableOfContents headings={headings} />
      </aside>
      <div class="prose post-content">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
