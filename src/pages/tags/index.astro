---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TagChip from '@/components/TagChip.astro';
import { getAllEntries, getUniqueTags } from '@/lib/content';

const entries = await getAllEntries();
const tags = getUniqueTags(entries);
---

<BaseLayout title="标签" description="查看全站标签索引。">
  <div class="container">
    <header class="page-header">
      <p class="eyebrow">Tags</p>
      <h1 class="page-title">标签索引</h1>
      <p class="page-lead">标签是跨栏目检索的第二层目录，尤其适合把阅读、笔记和项目串在一起看。</p>
    </header>

    <div class="footer-tags">
      {tags.map((tag) => <TagChip tag={tag} />)}
    </div>
  </div>
</BaseLayout>

