---
import BaseLayout from '@/layouts/BaseLayout.astro';
import EntryCard from '@/components/EntryCard.astro';
import TagChip from '@/components/TagChip.astro';
import {
  COLLECTIONS,
  collectionMeta,
  getAllEntries,
  getEntries,
  getUniqueTags,
} from '@/lib/content';
import { SITE_DESCRIPTION, SITE_TITLE } from '@/site.config';
import { withBase } from '@/lib/urls';

const allEntries = await getAllEntries();
const latestEntries = allEntries.slice(0, 6);
const tagList = getUniqueTags(allEntries).slice(0, 12);
const collectionSummaries = await Promise.all(
  COLLECTIONS.map(async (collection) => ({
    key: collection,
    meta: collectionMeta[collection],
    count: (await getEntries(collection)).length,
  })),
);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <div class="container">
    <section class="hero hero--minimal">
      <div class="hero__copy">
        <p class="eyebrow">PERSONAL KNOWLEDGE SYSTEM</p>
        <h1>简洁、可检索、长期维护的个人技术博客。</h1>
        <p>
          这里用来放阅读笔记、学习整理、生活记录和项目日志。风格尽量克制，结构尽量清楚，
          让内容本身成为主角。
        </p>
        <div class="hero__actions">
          <a class="button-link button-link--primary" href={withBase('/notes/')}>
            Start reading
          </a>
          <a class="button-link button-link--secondary" href={withBase('/search/')}>
            Search index
          </a>
        </div>
        <ul class="hero__stats">
          <li>
            <span>entries</span>
            <strong>{allEntries.length}</strong>
          </li>
          <li>
            <span>sections</span>
            <strong>{collectionSummaries.length}</strong>
          </li>
          <li>
            <span>deploy</span>
            <strong>GitHub Pages</strong>
          </li>
        </ul>
      </div>

      <div class="hero__visual">
        <div class="hero-terminal">
          <div class="hero-terminal__top">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="hero-terminal__body">
            <img
              class="hero-terminal__logo"
              src={withBase('/brand-logo.jpg')}
              alt="Site logo"
              width="960"
              height="640"
            />
            <div class="hero-terminal__meta">
              <p>$ tree content</p>
              <p>blog/ reading/ notes/ projects/</p>
              <p>$ status: active knowledge garden</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <h2 class="section-title">Sections</h2>
          <p>四个栏目分工明确，适合长期写作和归档。</p>
        </div>
      </div>
      <div class="collection-grid">
        {
          collectionSummaries.map(({ key, meta, count }) => (
            <a class="collection-tile" href={withBase(`/${key}/`)}>
              <p class="eyebrow">{meta.summary}</p>
              <h3>{meta.title}</h3>
              <p>{meta.description}</p>
              <small>{count} entries</small>
            </a>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <h2 class="section-title">Latest Updates</h2>
          <p>先看最近在写什么，再决定往哪个分区继续深入。</p>
        </div>
        <a class="button-link button-link--secondary" href={withBase('/archive/')}>
          View archive
        </a>
      </div>
      <div class="entry-grid">
        {latestEntries.map((entry) => <EntryCard entry={entry} showCollection />)}
      </div>
    </section>

    <section class="section section--compact">
      <div class="section-header">
        <div>
          <h2 class="section-title">Common Tags</h2>
          <p>跨栏目检索时，标签是最快的入口。</p>
        </div>
      </div>
      <div class="footer-tags">
        {tagList.map((tag) => <TagChip tag={tag} />)}
      </div>
    </section>
  </div>
</BaseLayout>
