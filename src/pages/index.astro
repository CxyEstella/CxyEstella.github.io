---
import BaseLayout from '@/layouts/BaseLayout.astro';
import EntryCard from '@/components/EntryCard.astro';
import { getAllEntries } from '@/lib/content';
import { SITE_DESCRIPTION, SITE_TITLE } from '@/site.config';
import { withBase } from '@/lib/urls';

const allEntries = await getAllEntries();
const latestEntries = allEntries.slice(0, 8);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <div class="container">
    <section class="hero hero--single">
      <div class="hero__copy">
        <p class="eyebrow">PERSONAL KNOWLEDGE SYSTEM</p>
        <h1>清楚一点，安静一点，内容优先。</h1>
        <p>
          这里用来放阅读笔记、学习整理、生活记录和项目日志。页面尽量克制，结构尽量清楚，
          方便长期积累和回看。
        </p>
        <div class="hero__actions">
          <a class="button-link button-link--primary" href={withBase('/notes/')}>
            Notes
          </a>
          <a class="button-link button-link--secondary" href={withBase('/reading/')}>
            Reading
          </a>
          <a class="button-link button-link--secondary" href={withBase('/projects/')}>
            Projects
          </a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <h2 class="section-title">Latest</h2>
          <p>最近更新的内容。</p>
        </div>
        <a class="button-link button-link--secondary" href={withBase('/archive/')}>
          Archive
        </a>
      </div>
      <div class="entry-grid">
        {latestEntries.map((entry) => <EntryCard entry={entry} showCollection />)}
      </div>
    </section>
  </div>
</BaseLayout>
