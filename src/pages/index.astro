---
import BaseLayout from '@/layouts/BaseLayout.astro';
import EntryCard from '@/components/EntryCard.astro';
import { getAllEntries } from '@/lib/content';
import { SITE_DESCRIPTION, SITE_TITLE } from '@/site.config';
import { withBase } from '@/lib/urls';

const allEntries = await getAllEntries();
const latestEntries = allEntries.slice(0, 8);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <div class="container">
    <section class="hero hero--single hero--landing">
      <div class="hero__copy">
        <p class="eyebrow">FLOW / INDEX</p>
        <h1>Quiet structure for reading, notes, and project logs.</h1>
        <p>A personal system for literature reading, study notes, everyday writing, and project records.</p>
        <div class="hero__actions">
          <a class="button-link button-link--primary" href={withBase('/notes/')}>
            Notes
          </a>
          <a class="button-link button-link--secondary" href={withBase('/reading/')}>
            Reading
          </a>
          <a class="button-link button-link--secondary" href={withBase('/projects/')}>
            Projects
          </a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <h2 class="section-title">Recent Index</h2>
          <p>Latest updates across all collections.</p>
        </div>
        <a class="button-link button-link--secondary" href={withBase('/archive/')}>
          Archive
        </a>
      </div>
      <div class="entry-list">
        {latestEntries.map((entry) => <EntryCard entry={entry} showCollection />)}
      </div>
    </section>
  </div>
</BaseLayout>
