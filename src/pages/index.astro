---
import BaseLayout from '@/layouts/BaseLayout.astro';
import EntryCard from '@/components/EntryCard.astro';
import TagChip from '@/components/TagChip.astro';
import {
  COLLECTIONS,
  collectionMeta,
  getAllEntries,
  getEntries,
  getUniqueTags,
} from '@/lib/content';
import { SITE_DESCRIPTION, SITE_TITLE } from '@/site.config';
import { withBase } from '@/lib/urls';

const allEntries = await getAllEntries();
const latestEntries = allEntries.slice(0, 6);
const tagList = getUniqueTags(allEntries).slice(0, 14);
const collectionSummaries = await Promise.all(
  COLLECTIONS.map(async (collection) => ({
    key: collection,
    meta: collectionMeta[collection],
    count: (await getEntries(collection)).length,
  })),
);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <div class="container">
    <section class="hero">
      <div class="hero__copy">
        <p class="eyebrow">个人知识花园</p>
        <h1>把阅读、学习、生活和项目过程，慢慢写成一座可检索的花园。</h1>
        <p>
          这里用来放文献阅读笔记、生活记录、学习沉淀与项目日志。文章支持
          Markdown、图片、数学公式和带高亮的代码块，也提供了站内搜索与暗色模式。
        </p>
        <div class="hero__actions">
          <a class="button-link button-link--primary" href={withBase('/search/')}>
            开始搜索
          </a>
          <a class="button-link button-link--secondary" href={withBase('/reading/')}>
            浏览阅读笔记
          </a>
        </div>
        <ul class="hero__stats">
          <li>共 {allEntries.length} 篇内容</li>
          <li>{collectionSummaries.length} 个分区</li>
          <li>支持 RSS 订阅</li>
        </ul>
      </div>

      <div class="panel">
        <div class="panel" style="padding: 1.4rem;">
          <p class="eyebrow">内容结构</p>
          <div class="tag-stack">
            {
              collectionSummaries.map(({ key, meta, count }) => (
                <a class="collection-tile" href={withBase(`/${key}/`)}>
                  <h3>{meta.title}</h3>
                  <p>{meta.description}</p>
                  <small>{count} 篇内容</small>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <h2 class="section-title">最新更新</h2>
          <p>按更新时间排序，方便你先看到最近在写什么。</p>
        </div>
        <a class="button-link button-link--secondary" href={withBase('/archive/')}>
          查看归档
        </a>
      </div>
      <div class="entry-grid">
        {latestEntries.map((entry) => <EntryCard entry={entry} showCollection />)}
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <h2 class="section-title">按分区阅读</h2>
          <p>四个栏目分别承担不同写作目的，结构清晰，后续扩展也方便。</p>
        </div>
      </div>
      <div class="collection-grid">
        {
          collectionSummaries.map(({ key, meta, count }) => (
            <a class="collection-tile" href={withBase(`/${key}/`)}>
              <p class="eyebrow">{meta.summary}</p>
              <h3>{meta.title}</h3>
              <p>{meta.description}</p>
              <small>{count} 篇内容</small>
            </a>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <h2 class="section-title">常用标签</h2>
          <p>标签页适合做跨分区查找，比如一个主题同时出现在阅读和项目记录里。</p>
        </div>
        <a class="button-link button-link--secondary" href={withBase('/tags/')}>
          所有标签
        </a>
      </div>
      <div class="footer-tags">
        {tagList.map((tag) => <TagChip tag={tag} />)}
      </div>
    </section>
  </div>
</BaseLayout>

