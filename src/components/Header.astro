---
import ThemeToggle from '@/components/ThemeToggle.astro';
import { NAV_LINKS, SITE_TITLE } from '@/site.config';
import { withBase } from '@/lib/urls';

const pathname = Astro.url.pathname;

function isActive(href: string) {
  const resolved = withBase(href);
  return href === '/'
    ? pathname === resolved
    : pathname === resolved || pathname.startsWith(resolved);
}
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href={withBase('/')}>
      <img
        class="site-header__brand-logo"
        src={withBase('/brand-logo.jpg')}
        alt={`${SITE_TITLE} logo`}
        width="48"
        height="48"
      />
      <span>
        <strong class="site-header__brand-text">{SITE_TITLE}</strong>
        <span class="site-header__brand-subtitle">notes / reading / projects</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="主导航">
      {
        NAV_LINKS.map((link) => (
          <a
            class:list={['site-nav__link', { 'is-active': isActive(link.href) }]}
            href={withBase(link.href)}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="site-header__actions">
      <form action={withBase('/search/')} class="search-mini" role="search">
        <label class="sr-only" for="site-search-mini">
          站内搜索
        </label>
        <input
          id="site-search-mini"
          class="search-mini__input"
          type="search"
          name="q"
          placeholder="搜索文章 / 标签 / 项目"
        />
      </form>
      <ThemeToggle />
    </div>
  </div>
</header>
