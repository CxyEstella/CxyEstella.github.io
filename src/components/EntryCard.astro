---
import {
  collectionMeta,
  estimateReadingMinutes,
  formatCompactDate,
  getEntryUrl,
  type AnyEntry,
} from '@/lib/content';
import { withBase } from '@/lib/urls';

interface Props {
  entry: AnyEntry;
  showCollection?: boolean;
}

const { entry, showCollection = false } = Astro.props;
const meta = collectionMeta[entry.collection];
---

<article class="entry-card">
  <div class="entry-card__meta">
    {
      showCollection && (
        <span class="entry-card__collection">
          {meta.title}
        </span>
      )
    }
    <span>{formatCompactDate(entry.data.pubDate)}</span>
    <span>{estimateReadingMinutes(entry)} min</span>
  </div>

  <h3 class="entry-card__title">
    <a href={withBase(getEntryUrl(entry))}>{entry.data.title}</a>
  </h3>

  <p class="entry-card__description">{entry.data.description}</p>
</article>
